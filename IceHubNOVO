    local function getLeaderstat(name)
        local ls = player:FindFirstChild("leaderstats")
        if ls then
            local stat = ls:FindFirstChild(name)
            if stat then
                if stat:IsA("NumberValue") then return stat.Value end
                if stat:IsA("IntValue") then return stat.Value end
            end
        end
        return 0
    end
    
    local function getLevel() return getLeaderstat("Level") end
    local function getMoney() return getLeaderstat("Money") end
    local function getFragments() return getLeaderstat("Fragments") end
    local function getBones()
        local bones = player:FindFirstChild("Bones")
        if bones and bones:IsA("NumberValue") then return bones.Value end
        return 0
    end
    local function getEctoplasm()
        local ecto = player:FindFirstChild("Ectoplasm")
        if ecto and ecto:IsA("NumberValue") then return ecto.Value end
        return 0
    end
    local function getEquippedFruit()
        local fruit = player:FindFirstChild("EquippedFruit")
        if fruit and fruit:IsA("StringValue") then return fruit.Value end
        return "Nenhuma"

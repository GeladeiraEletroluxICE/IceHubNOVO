-- =====================================================
-- COMPLEMENTO ANIMADO COM ESCALA CENTRALIZADA (CORRIGIDO)
-- =====================================================
do
    local TweenService = game:GetService("TweenService")
    local hub = LMG2L["HUB_2"]
    local botaoFrame = LMG2L["BOTAO_1e"]
    local btnMinimizar = LMG2L["TextButton_1b"]
    local btnFloco = LMG2L["TextButton_22"]
    
    -- Ajustar AnchorPoint para centralizar a escala, mantendo a posição visual
    local function centralizarElemento(elemento, posicaoOriginalUDim2)
        local originalPosition = posicaoOriginalUDim2 or elemento.Position
        elemento.AnchorPoint = Vector2.new(0.5, 0.5)
        task.wait()
        local absSize = elemento.AbsoluteSize
        local screenSize = elemento.Parent.AbsoluteSize
        local offsetX = (absSize.X / 2) / screenSize.X
        local offsetY = (absSize.Y / 2) / screenSize.Y
        elemento.Position = UDim2.new(originalPosition.X.Scale + offsetX, originalPosition.X.Offset, originalPosition.Y.Scale + offsetY, originalPosition.Y.Offset)
    end
    
    -- Guardar posições originais
    local hubPosOriginal = hub.Position
    local botaoPosOriginal = botaoFrame.Position
    
    -- Centralizar HUB e botão
    centralizarElemento(hub, hubPosOriginal)
    centralizarElemento(botaoFrame, botaoPosOriginal)
    
    -- Adicionar UIScale
    local hubScale = Instance.new("UIScale")
    hubScale.Parent = hub
    local botaoScale = Instance.new("UIScale")
    botaoScale.Parent = botaoFrame
    
    -- Estado inicial: HUB visível (scale 1), botão invisível (scale 0)
    hubScale.Scale = 1
    botaoScale.Scale = 0
    botaoFrame.Visible = false
    
    local ANIM_TIME = 0.25
    
    -- Função para encolher até sumir
    local function shrinkAndHide(element, scaleObject, targetScale)
        local tween = TweenService:Create(scaleObject, TweenInfo.new(ANIM_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = targetScale})
        tween:Play()
        tween.Completed:Connect(function()
            if targetScale == 0 then
                element.Visible = false
            end
        end)
    end
    
    -- Função para crescer a partir do zero
    local function growAndShow(element, scaleObject)
        element.Visible = true
        scaleObject.Scale = 0
        local tween = TweenService:Create(scaleObject, TweenInfo.new(ANIM_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
        tween:Play()
    end
    
    -- Minimizar HUB: encolher e esconder (agora sem definir hub.Visible manualmente)
    btnMinimizar.MouseButton1Click:Connect(function()
        if hub.Visible then
            shrinkAndHide(hub, hubScale, 0)
            -- O tween define hub.Visible = false ao terminar
            -- Mostrar botão floco apenas depois que o HUB sumir completamente
            task.wait(ANIM_TIME)  -- aguarda o término da animação do hub
            if not hub.Visible then
                growAndShow(botaoFrame, botaoScale)
            end
        end
    end)
    
    -- Abrir HUB: encolher botão e depois crescer HUB
    btnFloco.MouseButton1Click:Connect(function()
        if not hub.Visible then
            -- Esconder botão com encolhimento
            shrinkAndHide(botaoFrame, botaoScale, 0)
            task.wait(ANIM_TIME)  -- espera o botão sumir
            if not botaoFrame.Visible then
                growAndShow(hub, hubScale)
            end
        end
    end)
    
    -- ========== HOVER EFFECTS (mantidos) ==========
    local function addHoverEffect(button, scaleFactor, originalColor)
        if not button then return end
        local originalScale = button.Size
        local originalColor3 = originalColor or button.BackgroundColor3
        button.MouseEnter:Connect(function()
            local tween = TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
                {Size = UDim2.new(originalScale.X.Scale * scaleFactor, originalScale.X.Offset, originalScale.Y.Scale * scaleFactor, originalScale.Y.Offset)})
            tween:Play()
            if originalColor then
                local colorTween = TweenService:Create(button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(180, 230, 255)})
                colorTween:Play()
            end
        end)
        button.MouseLeave:Connect(function()
            local tween = TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = originalScale})
            tween:Play()
            if originalColor then

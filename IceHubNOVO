do
    local function transformarEmLabel(textBox, novoTexto)
        local parent = textBox.Parent
        local pos = textBox.Position
        local size = textBox.Size
        local bgColor = textBox.BackgroundColor3
        local textColor = textBox.TextColor3
        local font = textBox.FontFace
        local textSize = textBox.TextSize
        local cornerRadius = nil
        for _, child in ipairs(textBox:GetChildren()) do
            if child:IsA("UICorner") then
                cornerRadius = child.CornerRadius
                child:Destroy()
                break
            end
        end
        
        -- Criar TextLabel com as mesmas propriedades
        local label = Instance.new("TextLabel")
        label.Parent = parent
        label.Position = pos
        label.Size = size
        label.BackgroundColor3 = bgColor
        label.TextColor3 = textColor
        label.FontFace = font
        label.TextSize = textSize
        label.Text = novoTexto or textBox.Text
        label.BackgroundTransparency = textBox.BackgroundTransparency
        label.BorderSizePixel = textBox.BorderSizePixel
        label.TextStrokeTransparency = textBox.TextStrokeTransparency
        label.TextWrapped = textBox.TextWrapped
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.TextYAlignment = Enum.TextYAlignment.Center
        
        -- Recriar o UICorner se existia
        if cornerRadius then
            local newCorner = Instance.new("UICorner")
            newCorner.CornerRadius = cornerRadius
            newCorner.Parent = label
        end
        
        -- Remover o TextBox original
        textBox:Destroy()
        
        -- Atualizar referência no LMG2L
        if textBox == LMG2L["TextBox_15"] then
            LMG2L["TextBox_15"] = label
        elseif textBox == LMG2L["TextBox_18"] then
            LMG2L["TextBox_18"] = label
        end
    end
    
    -- Aplicar transformação
    transformarEmLabel(LMG2L["TextBox_15"], "ICE HUB🌨️  (Blox Fruits)")
    transformarEmLabel(LMG2L["TextBox_18"], "CATEGORIA :")
end


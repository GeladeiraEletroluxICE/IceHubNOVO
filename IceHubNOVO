        -- Ajustar canvas size dinamicamente após preenchimento
        task.wait()
        local totalHeight = 0
        for _, child in ipairs(scroll:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextLabel") then
                totalHeight = totalHeight + child.Size.Y.Offset + (layout.Padding.Offset or 8)
            end
        end
        scroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight + 50)
    end
    
    -- ========== LOOP DE ATUALIZAÇÃO ==========
    local function atualizarDados()
        if not isMainActive then return end
        if currentScroll then
            preencherScroll(currentScroll)
        end
    end
    
    -- ========== ATIVAR ABA MAIN ==========
    local function ativarMain()
        isMainActive = true
        if updateConnection then updateConnection:Disconnect() end
        updateConnection = RunService.Heartbeat:Connect(function()
            -- Atualiza a cada ~1 segundo
            wait(1)
            if isMainActive then
                atualizarDados()
            end
        end)
        -- Cria o scroll se não existir
        if not currentScroll then
            currentScroll = criarScroll()
        end
        preencherScroll(currentScroll)
        categoriaLabel.Text = "CATEGORIA : Main (Progresso)"
    end
    
    -- ========== DESATIVAR ==========
    local function desativarMain()
        isMainActive = false
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
        if currentScroll then
            currentScroll:Destroy()
            currentScroll = nil
        end
    end
    
    -- ========== CONECTAR AO BOTÃO MAIN ==========
    -- Primeiro, precisamos interceptar o clique do botão MAIN sem perder o comportamento original de mudar o texto da categoria.
    -- O script original já tem um evento que muda o texto. Vamos apenas adicionar o nosso.
    -- Como o botão MAIN já tem um evento conectado (do complemento de atualizar categoria), vamos adicionar mais um.
    btnMain.MouseButton1Click:Connect(function()
        -- Se já estiver ativo, não recria
        if isMainActive then
            -- apenas garante que o scroll está visível
            if not currentScroll then
                currentScroll = criarScroll()
                preencherScroll(currentScroll)
            end
        else
            desativarMain() -- limpa possível estado anterior
            ativarMain()
        end
    end)
    
    -- Inicialmente, se a aba Main estiver ativa por padrão? Por padrão o HUB já mostra a categoria "MAIN" (do script original), mas sem conteúdo. Vamos ativar ao iniciar.
    -- Para não conflitar, esperamos um pouco e ativamos.
    task.wait(0.5)
    ativarMain()
end
